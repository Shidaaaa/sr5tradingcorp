# Server runtime
NODE_ENV=development
PORT=5000

# Security
JWT_SECRET=replace_with_a_long_random_secret
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sr5trading

# Frontend/Backend URLs
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5000

# Stripe (card payments)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# PayMongo (GCash)
PAYMONGO_SECRET_KEY=sk_test_xxx
PAYMONGO_WEBHOOK_SECRET=whsk_xxx
PAYMONGO_API_BASE_URL=https://api.paymongo.com/v1
PAYMONGO_WEBHOOK_URL=https://your-public-domain.ngrok-free.dev/api/payments/paymongo/webhook
